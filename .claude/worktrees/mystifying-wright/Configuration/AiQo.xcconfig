// Shared build settings for the main AiQo app target.
// Secrets.xcconfig can override these defaults locally when needed.

// Work around Xcode explicit-module failures from SDWebImageSwiftUI.
CLANG_ENABLE_EXPLICIT_MODULES = NO
SWIFT_ENABLE_EXPLICIT_MODULES = NO

SUPABASE_URL =
SUPABASE_ANON_KEY =

#include? "Secrets.xcconfig"
