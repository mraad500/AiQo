<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CAPTAIN_ARABIC_API_URL</key>
	<string>$(CAPTAIN_ARABIC_API_URL)</string>
	<key>COACH_BRAIN_LLM_API_KEY</key>
	<string>$(COACH_BRAIN_LLM_API_KEY)</string>
	<key>COACH_BRAIN_LLM_API_URL</key>
	<string>$(COACH_BRAIN_LLM_API_URL)</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.mraad500.aiqo</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aiqo</string>
				<string>aiqo-spotify</string>
			</array>
		</dict>
	</array>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>spotify</string>
	</array>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSMicrophoneUsageDescription</key>
	<string>AiQo uses the microphone for hands-free Zone 2 coaching while you stay in motion.</string>
	<key>NSHealthShareUsageDescription</key>
	<string>AiQo uses HealthKit on iPhone to coordinate Apple Watch workouts and show live heart rate, calories, distance, and elapsed time.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>AiQo uses HealthKit on iPhone to launch and manage Apple Watch workout sessions that are saved to Apple Health.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>AiQo transcribes your short voice cues so Captain can answer locally during Zone 2 sessions.</string>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>aiqo.captain.spiritual-whispers.refresh</string>
	</array>
	<key>SPIRITUAL_WHISPERS_LLM_API_URL</key>
	<string>https://api.openai.com/v1/chat/completions</string>
	<key>SPIRITUAL_WHISPERS_LLM_API_KEY</key>
	<string></string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>remote-notification</string>
		<string>fetch</string>
	</array>
</dict>
</plist>
