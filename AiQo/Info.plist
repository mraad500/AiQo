<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>AIQO_CHAT_V1_1_ENABLED</key>
	<true/>
	<key>AIQO_DEV_UNLOCK_ALL</key>
	<false/>
	<key>AUDIT_LOGGER_VERBOSE</key>
	<false/>
	<key>BGTaskSchedulerPermittedIdentifiers</key>
	<array>
		<string>aiqo.notifications.refresh</string>
		<string>aiqo.notifications.inactivity-check</string>
		<string>aiqo.brain.nightly</string>
	</array>
	<!--
	  BRAIN_DASHBOARD_ENABLED — Dead flag as of v1.0.4. Declared so a future build
	  can flip the in-app debug dashboard (BrainDashboard.swift) on without an
	  additional plist add. Currently no functional reader uses it.
	-->
	<key>BRAIN_DASHBOARD_ENABLED</key>
	<false/>
	<key>CAPTAIN_API_KEY</key>
	<string>$(CAPTAIN_API_KEY)</string>
		<key>CAPTAIN_BRAIN_V2_ENABLED</key>
		<true/>
		<!--
		  CAPTAIN_QUALITY_REGEN_ENABLED — Quality-regeneration loop in
		  BrainOrchestrator.swift:338. Reads via Bundle.main.infoDictionary
		  with default false. Declared here so the read is no longer a
		  "ghost flag" (declared in code, missing from plist).
		-->
		<key>CAPTAIN_QUALITY_REGEN_ENABLED</key>
		<false/>
		<key>CAPTAIN_VOICE_API_KEY</key>
		<string>$(CAPTAIN_VOICE_API_KEY)</string>
		<key>CAPTAIN_VOICE_API_URL</key>
		<string>$(CAPTAIN_VOICE_API_URL)</string>
		<key>CAPTAIN_VOICE_CLOUD_ENABLED</key>
		<true/>
		<key>CAPTAIN_VOICE_MODEL_ID</key>
		<string>$(CAPTAIN_VOICE_MODEL_ID)</string>
		<key>CAPTAIN_VOICE_VOICE_ID</key>
		<string>$(CAPTAIN_VOICE_VOICE_ID)</string>
		<key>CFBundleURLTypes</key>
		<array>
			<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLName</key>
			<string>com.mraad500.aiqo</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>aiqo</string>
				<string>aiqo-spotify</string>
			</array>
		</dict>
	</array>
	<key>COACH_BRAIN_LLM_API_KEY</key>
	<string>$(COACH_BRAIN_LLM_API_KEY)</string>
	<!--
	  GEMINI_3_PREVIEW_ENABLED — Master kill switch for the gemini-3-flash-preview
	  reasoning model. OFF by default: preview models can change behavior, hit
	  tighter rate limits, or be withdrawn by Google without notice, so we do not
	  bind the paid Pro tier to one unless we opt in. When OFF, GeminiModelPolicy
	  routes every cloud call (chat, kitchen, memory extraction, weekly review) to
	  the stable gemini-2.5-flash. The captain-chat Edge Function whitelists both
	  models, so this flip is client-side only. CloudBrain also auto-falls-back to
	  gemini-2.5-flash if a preview call errors/times out.
	-->
	<key>GEMINI_3_PREVIEW_ENABLED</key>
	<false/>
	<!--
	  CRISIS_DETECTOR_ENABLED — As of v1.0.4 wires CrisisDetector.shared
	  registration in AppDelegate. Previously dead (declared but unread).
	  CrisisDetector is a passive safety-net actor that listens to emotional
	  pattern + bio signals; instantiation is sufficient to wire it.
	-->
	<key>CRISIS_DETECTOR_ENABLED</key>
	<true/>
	<!--
	  LEARNING_CHALLENGE_V2_ENABLED — Dead at the call-site level. Only the
	  property wrapper at AiQoFeatureFlags.swift:111 exists; no functional
	  reader. Retained for dark-launch rollback path per the comment in
	  AiQoFeatureFlags.swift.
	-->
	<key>LEARNING_CHALLENGE_V2_ENABLED</key>
	<true/>
	<key>LEARNING_SPARK_STAGE2_ENABLED</key>
	<true/>
	<key>LEARNING_VERIFICATION_ON_DEVICE_ENABLED</key>
	<true/>
	<!--
	  HIGH_FIDELITY_3D_ENABLED — Master switch for full-fidelity 3D: the OutdoorRun
	  realistic-elevation satellite map + pitched cinematic chase camera, and the
	  RealityKit Captain avatar. ON by default. DevicePerformanceTier additionally
	  auto-downgrades on lower-RAM devices (< ~5 GB) and under thermal stress
	  (.serious/.critical). Set to NO to force the lighter path everywhere (flat
	  imagery, fixed follow camera, 2D avatar). Never removes the feature.
	-->
	<key>HIGH_FIDELITY_3D_ENABLED</key>
	<true/>
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>spotify</string>
		<string>spotify-action</string>
		<string>instagram-stories</string>
		<string>instagram</string>
	</array>
	<!--
	  MEMORY_V4_ENABLED — Globally ON as of v1.0.4. The runtime gate at
	  MemoryV4Gate.isOn ALSO checks the remote Supabase kill switch
	  (memory_v4_globally_disabled) and the local migration-failure fallback
	  flag (aiqo.memory.v4.disabled.fallback). Flip back to false here only
	  as a "kill V4 in next build" — for live disable use the Supabase row.
	-->
	<key>MEMORY_V4_ENABLED</key>
	<true/>
	<!--
	  NOTIFICATION_BRAIN_ENABLED — As of v1.0.4 wires NotificationBrain.shared.subscribe()
	  in AppDelegate. Listens for XP grants, streak increments, and streak risk.
	  Hard-capped at 1 notification per 4 hours and 3 per day (NotificationBrain.swift)
	  on top of the existing GlobalBudget pipeline.
	-->
	<key>NOTIFICATION_BRAIN_ENABLED</key>
	<true/>
	<key>NSAlarmKitUsageDescription</key>
	<string>AiQo uses alarm access to save your smart wake time as an alarm on your device.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>During an Outdoor Running workout, AiQo uses your location to map your route and measure distance, pace and elevation. Tracking continues in the background with the screen locked until you end the run. Your location stays on your device.</string>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
	<key>NSUserActivityTypes</key>
	<array>
		<string>com.aiqo.startWalk</string>
		<string>com.aiqo.startRun</string>
		<string>com.aiqo.startHIIT</string>
		<string>com.aiqo.openCaptain</string>
		<string>com.aiqo.todaySummary</string>
		<string>com.aiqo.logWater</string>
		<string>com.aiqo.openKitchen</string>
		<string>com.aiqo.weeklyReport</string>
	</array>
	<key>PLANK_LADDER_CHALLENGE_ENABLED</key>
	<false/>
	<key>SMART_WATER_TRACKING_ENABLED</key>
	<true/>
	<!--
	  PROACTIVE_CULTURAL_ENABLED — Dead. Reserved for the Ramadan/Eid/Jumuah
	  trigger path inside CulturalTrigger; no current reader. Flag stays for
	  remote-config parity once we ship the back-channel.
	-->
	<key>PROACTIVE_CULTURAL_ENABLED</key>
	<false/>
	<!--
	  PROACTIVE_EMOTIONAL_ENABLED — Dead. Reserved for EmotionalFollowUpTrigger /
	  MoodShiftTrigger gating. The triggers themselves register unconditionally
	  inside the V4 cascade today.
	-->
	<key>PROACTIVE_EMOTIONAL_ENABLED</key>
	<false/>
	<!--
	  PROACTIVE_MEMORY_CALLBACK_ENABLED — Dead. Reserved for MemoryCallbackTrigger
	  gating. Same situation as PROACTIVE_EMOTIONAL_ENABLED.
	-->
	<key>PROACTIVE_MEMORY_CALLBACK_ENABLED</key>
	<false/>
	<key>SAFARI_VIEW_CONTROLLER_ENABLED</key>
	<true/>
	<key>SPOTIFY_CLIENT_ID</key>
	<string>$(SPOTIFY_CLIENT_ID)</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>$(SUPABASE_ANON_KEY)</string>
	<key>SUPABASE_URL</key>
	<string>$(SUPABASE_URL)</string>
	<key>TRIBE_BACKEND_ENABLED</key>
	<false/>
	<!--
	  TRIBE_FEATURE_VISIBLE — Dead at the read-site level (only comment refs in
	  TribeExperienceFlow.swift). Retained because the Tribe surface is still in
	  dev and TRIBE_BACKEND_ENABLED + TRIBE_SUBSCRIPTION_GATE_ENABLED rely on
	  the same triplet of flags to be coherent when we ship Tribe v2.
	-->
	<key>TRIBE_FEATURE_VISIBLE</key>
	<false/>
	<key>TRIBE_SUBSCRIPTION_GATE_ENABLED</key>
	<false/>
	<key>KERNEL_ENABLED</key>
	<true/>
	<key>USE_CLOUD_PROXY</key>
	<string>$(USE_CLOUD_PROXY)</string>
	<key>USE_CHAT_CLOUD_PROXY</key>
	<string>$(USE_CHAT_CLOUD_PROXY)</string>
	<key>USE_VOICE_CLOUD_PROXY</key>
	<string>$(USE_VOICE_CLOUD_PROXY)</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>remote-notification</string>
		<string>fetch</string>
		<string>processing</string>
		<string>location</string>
	</array>
</dict>
</plist>
